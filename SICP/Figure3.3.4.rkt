(define (half-adder a b s c)
  (let ((d (make-wire))
        (e (make-wire)))
    (inverter c e)
    (and-gate d e s)
    (or-gate a b d)
    (and-gate a b c)
    'ok))

(define (full-adder a b c-in sum c-out)
  (let ((s (make-wire))
        (c1 (make-wire))
        (c2 (make-wire)))
    (half-adder b c-in s c1)
    (half-adder a s sum c2)
    (or-gate c1 c2 c-out)
    'ok))
