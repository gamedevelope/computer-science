      (b (make-wire))
      (s (make-wire))
      (c (make-wire)))
  (half-adder a b s c)
  (set-signal! a 1)
  (set-signal! b 0)
  (propagate)
  (display (list "s :" (get-signal s) "c :" (get-signal c))))